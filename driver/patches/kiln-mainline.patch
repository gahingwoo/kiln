+/*
+ * KILN: enable ALL four NPU MMU banks (both cores).
+ *
+ * The vendor NPU is one platform device with two IOMMUs (rknpu_mmu_0/1), but
+ * mainline rockchip-iommu only manages a single primary iommu per device
+ * (dev_iommu_priv_get), so only one core's MMU (2 banks) is ever attached +
+ * enabled. The orphan core's MMU stays disabled (paging off, DTE=0): its jobs
+ * read the regcmd IOVA as a raw physical address -> garbage -> task_counter=0,
+ * no page fault. And rknpu_soft_reset() (issued on every job timeout) resets
+ * the cores incl. both MMUs, which the iommu driver never re-enables.
+ *
+ * Fix: learn the domain's page-directory base from whichever bank the kernel
+ * enabled (cached in mmu_dte), then mirror it onto every disabled bank with the
+ * minimal rk_iommu enable sequence (write DTE, ZAP, unmask IRQ, ENABLE_PAGING).
+ * Banks are at NPU_base[core] + 0x2000 / +0x2100; register offsets match
+ * drivers/iommu/rockchip-iommu.c (DTE=0x00, STATUS=0x04, COMMAND=0x08,
+ * INT_MASK=0x1c; CMD ZAP=4, ENABLE_PAGING=0; STATUS bit0 = paging enabled).
+ * Must be called with both NPU power domains on (i.e. after power/clocks up).
+ */
+void rknpu_mmu_enable_all(struct rknpu_device *rknpu_dev)
+{
+	void __iomem *banks[4];
+	u32 dte = rknpu_dev->mmu_dte;
+	int b;
+
+	if (!rknpu_dev->iommu_en || !rknpu_dev->base[0] || !rknpu_dev->base[1])
+		return;
+
+	banks[0] = rknpu_dev->base[0] + 0x2000;
+	banks[1] = rknpu_dev->base[0] + 0x2100;
+	banks[2] = rknpu_dev->base[1] + 0x2000;
+	banks[3] = rknpu_dev->base[1] + 0x2100;
+
+	/* Learn the page-directory base from any bank the kernel already enabled. */
+	if (!dte) {
+		for (b = 0; b < 4; b++) {
+			u32 v = readl(banks[b] + 0x00);
+
+			if (v) {
+				dte = v;
+				break;
+			}
+		}
+		rknpu_dev->mmu_dte = dte;
+	}
+	if (!dte)
+		return;
+
+	for (b = 0; b < 4; b++) {
+		u32 st = readl(banks[b] + 0x04);
+		int i;
+
+		if (st & 0x1)			/* paging already enabled */
+			continue;
+		writel(dte, banks[b] + 0x00);	/* DTE_ADDR */
+		writel(4, banks[b] + 0x08);	/* CMD ZAP_CACHE */
+		writel(0x03, banks[b] + 0x1c);	/* INT_MASK: page-fault + bus-error */
+		writel(0, banks[b] + 0x08);	/* CMD ENABLE_PAGING */
+		for (i = 0; i < 100; i++) {
+			if (readl(banks[b] + 0x04) & 0x1)
+				break;
+			udelay(10);
+		}
+	}
+
+	LOG_DEV_INFO(rknpu_dev->dev,
+		     "kiln mmu enable_all: dte=%#x st=%#x/%#x/%#x/%#x\n", dte,
+		     readl(banks[0] + 0x04), readl(banks[1] + 0x04),
+		     readl(banks[2] + 0x04), readl(banks[3] + 0x04));
+}
