+					REG_READ(RKNPU_OFFSET_PC_DATA_ADDR),
+					REG_READ(RKNPU_OFFSET_PC_DMA_BASE_ADDR),
+					REG_READ(RKNPU_OFFSET_PC_TASK_CONTROL));
+				LOG_ERROR(
+					"\tkiln engage: cna_sp=%#x core_sp=%#x dpu_sp=%#x rdma_sp=%#x (bit16=engaged)\n",
+					REG_READ(0x1004), REG_READ(0x3004),
+					REG_READ(0x4004), REG_READ(0x5004));
 			}
 		}
 		rknpu_soft_reset(rknpu_dev);
