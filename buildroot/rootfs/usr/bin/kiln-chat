#!/bin/sh
# Kiln: chat with an LLM on the RK3576 NPU (librkllmrt). Config-driven -- model,
# context, sampling, system prompt and KV history come from /etc/kiln/config.ini
# (edit by hand; kiln-chat also has live slash commands -- type /help). Extra args
# are forwarded to the binary (old form still works: kiln-chat <model.rkllm> [new_tokens] [ctx]).
export LD_LIBRARY_PATH=/usr/lib

# ensure the vendor rknpu driver is loaded (normally auto-loaded at boot via
# /etc/modules-load.d/rknpu.conf; this is a fallback for a fresh, pre-reboot run).
if ! grep -q '^rknpu' /proc/modules 2>/dev/null; then
	KO="$(find "/lib/modules/$(uname -r)" -name 'rknpu.ko*' 2>/dev/null | head -1)"
	[ "$(id -u)" -eq 0 ] && S= || S=sudo   # loading a module needs root
	echo "kiln-chat: loading rknpu (needs root) ..."
	$S modprobe rknpu 2>/dev/null || $S insmod "$KO" 2>/dev/null
	sleep 1
fi
if ! grep -q '^rknpu' /proc/modules 2>/dev/null; then
	echo "kiln-chat: rknpu not loaded. Load it as root first:  sudo modprobe rknpu"
	echo "           (then: sudo dmesg | grep -i rknpu). It normally auto-loads at boot."
	exit 1
fi

# preflight the LLM model (config-driven), unless a model was given on the CLI
# (old form: kiln-chat <model.rkllm> ...). kiln-chat itself falls back to any
# *.rkllm in /opt/models if the configured one is missing, so only stop when there
# is NOTHING usable -- and then point at kiln-config instead of failing cryptically.
case "${1:-}" in
*.rkllm) : ;;   # explicit model given -- skip the config preflight
*)
	CONF="${KILN_CONFIG:-/etc/kiln/config.ini}"
	LLM_MODEL=$(awk '/^[ \t]*\[/{s=$0} s ~ /^[ \t]*\[llm\]/ && /^[ \t]*model[ \t]*=/{sub(/^[^=]*=/,"");sub(/[ \t]#.*/,"");gsub(/^[ \t]+|[ \t]+$/,"");print;exit}' "$CONF" 2>/dev/null)
	if { [ -z "$LLM_MODEL" ] || [ ! -f "$LLM_MODEL" ]; } && ! ls /opt/models/*.rkllm >/dev/null 2>&1; then
		echo "kiln-chat: no LLM model available."
		echo "  Kiln doesn't ship one. Put a *-rk3576-w4a16.rkllm in /opt/models, then pick it with:"
		echo "      sudo kiln-config  ->  LLM Settings  ->  model"
		echo "  (any .rkllm there works; see README for where to get one)."
		exit 1
	fi
	;;
esac

echo "Loading the model onto the NPU (takes a few seconds) ..."
exec rkllm_demo "$@"
